{
  "description": "Claude DX hooks for Feishu notifications",
  "hooks": {
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/script/hooks/notification.py",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/script/hooks/stop.py",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
