# Claude DX Configuration Example
# Copy relevant settings to ~/.claude/settings.local.json

# ===== 飞书应用机器人配置 (必需) =====

# 飞书应用ID (从飞书开发者后台获取)
# 获取方式:
# 1. 访问 https://open.feishu.cn/app
# 2. 创建企业自建应用
# 3. 在"凭证与基础信息"页面查看 App ID
FEISHU_APP_ID=cli_xxxxxxxxxxxxxx

# 飞书应用密钥 (从飞书开发者后台获取)
# 获取方式:
# 1. 在"凭证与基础信息"页面点击"查看"
# 2. 复制 App Secret
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# 消息接收者ID
# 用户: ou_xxxxxxxxxx (open_id)
# 群聊: oc_xxxxxxxxxx (chat_id)
#
# 获取用户 open_id:
# - 方式1: 飞书管理后台 > 通讯录 > 查看用户详情
# - 方式2: 让用户给机器人发消息,在事件回调中获取
#
# 获取群聊 chat_id:
# 1. 将机器人添加到群聊(群设置 > 群机器人)
# 2. 通过API获取群组列表或在事件中获取
FEISHU_RECEIVE_ID=ou_xxxxxxxxxx

# 接收者类型
# 可选值: open_id, chat_id, user_id, email
# - open_id: 发送给用户(推荐用于个人通知)
# - chat_id: 发送到群聊(推荐用于团队协作)
FEISHU_RECEIVE_ID_TYPE=open_id

# ===== 应用权限要求 =====
# 需要在飞书开放平台配置以下权限(需管理员审核):
# - im:message (发送消息)
# - im:message:send_as_bot (以应用身份发消息)

# ===== 可选配置 =====

# 日志级别 (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# 请求超时时间(秒)
TIMEOUT=10
